# Support channel config (US-022)
# Estos valores se usan en SupportChannelsCard en registro, publicacion y pago.
# Copiar a .env y ajustar por entorno. Cambia el correo cuando se migre la cuenta de soporte.
VITE_SUPPORT_EMAIL=contact@example.com
VITE_SUPPORT_OWNER=Nombre del responsable durante piloto
VITE_SUPPORT_RESPONSE_TIME=Respuesta inicial en menos de 15 minutos (L-V, 9:00 a 19:00, hora CDMX).
VITE_SUPPORT_UPCOMING_AUTOMATION=Proximamente: chatbot con AI para soporte guiado 24/7.
